function Test-IsAdmin {
    $identity = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = New-Object Security.Principal.WindowsPrincipal($identity)
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

function Get-SourceDirectory {
    if (-not [string]::IsNullOrWhiteSpace($PSScriptRoot)) {
        return $PSScriptRoot.TrimEnd('\')
    }

    if (-not [string]::IsNullOrWhiteSpace($PSCommandPath)) {
        return (Split-Path -Parent $PSCommandPath).TrimEnd('\')
    }

    $processPath = [System.Diagnostics.Process]::GetCurrentProcess().MainModule.FileName
    if (-not [string]::IsNullOrWhiteSpace($processPath)) {
        return (Split-Path -Parent $processPath).TrimEnd('\')
    }

    throw "Could not determine the application folder."
}

function ConvertTo-YamlEscapedValue {
    param([string]$Value)

    if ($null -eq $Value) {
        return ""
    }

    return $Value -replace "'", "''"
}

if (-not (Test-IsAdmin)) {
