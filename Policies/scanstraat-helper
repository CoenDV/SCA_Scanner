function Show-Step {
    param([int]$Step)

    $panel1.Visible = $false
    $panel2.Visible = $false
    $panel3.Visible = $false

    $btnBack.Enabled = $Step -gt 1
    $btnNext.Visible = $Step -lt 3
    $btnFinish.Visible = $Step -eq 3

    switch ($Step) {
        1 {
            $panel1.Visible = $true
        }
        2 {
            $panel2.Visible = $true
        }
        3 {
            $lblReadyReportPath.Text = $txtReportPath.Text.Trim()
            $panel3.Visible = $true
        }
    }

    $script:currentStep = $Step
}

$btnBack.Add_Click({
    if ($script:currentStep -gt 1) {
        Show-Step ($script:currentStep - 1)
    }
})

$btnNext.Add_Click({
    if ($script:currentStep -eq 1) {
        Show-Step 2
        return
    }

    if ($script:currentStep -eq 2) {
        Show-Step 3
    }
})

$btnFinish.Add_Click({
    try {
        Install-Files
        Register-WeeklyTask

        [System.Windows.Forms.MessageBox]::Show(
            "Installation completed successfully.`r`n`r`nTask: $taskName`r`nSchedule: Every Sunday at 05:00",
            "Done",
            [System.Windows.Forms.MessageBoxButtons]::OK,
            [System.Windows.Forms.MessageBoxIcon]::Information
        ) | Out-Null

        $form.Close()
    }
    catch {
        [System.Windows.Forms.MessageBox]::Show(
            "Installation failed.`r`n`r`n$($_.Exception.Message)",
            "Error",
            [System.Windows.Forms.MessageBoxButtons]::OK,
            [System.Windows.Forms.MessageBoxIcon]::Error
        ) | Out-Null
    }
})

