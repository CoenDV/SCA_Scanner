function New-Label {
    param(
        [string]$Text,
        [int]$X,
        [int]$Y,
        [int]$W = 680,
        [int]$H = 25,
        [System.Drawing.Font]$Font = $fontText
    )

    $label = New-Object System.Windows.Forms.Label
    $label.Text = $Text
    $label.Location = New-Object System.Drawing.Point($X, $Y)
    $label.Size = New-Object System.Drawing.Size($W, $H)
    $label.Font = $Font
    return $label
}

function New-TextBox {
    param(
        [string]$Text,
        [int]$X,
        [int]$Y,
        [int]$W = 520
    )

    $tb = New-Object System.Windows.Forms.TextBox
    $tb.Text = $Text
    $tb.Location = New-Object System.Drawing.Point($X, $Y)
    $tb.Size = New-Object System.Drawing.Size($W, 28)
    return $tb
}

$sourceDir      = Get-SourceDirectory
$exeName        = "SCAScanner-win-x64.exe"
$benchmarkName  = "cis_win2025.yml"
$taskName       = "RWS Scanstraat Weekly"

$sourceExe       = Join-Path $sourceDir $exeName
$sourceBenchmark = Join-Path $sourceDir $benchmarkName

$installDir      = Join-Path $env:ProgramFiles "RWS\Scanstraat"
$dataDir         = Join-Path $env:ProgramData "RWS\Scanstraat"
$logDir          = Join-Path $dataDir "logs"
$outDir          = Join-Path $dataDir "out"
$targetExe       = Join-Path $installDir $exeName
$targetBenchmark = Join-Path $installDir $benchmarkName
$configPath      = Join-Path $installDir "config.yml"

function Write-ConfigFile {
    $reportFile = Join-Path $outDir ("sca_report_{0}.txt" -f $env:COMPUTERNAME)
    $reportFileEscaped = ConvertTo-YamlEscapedValue $reportFile

    $content = @"
report_file: '$reportFileEscaped'
"@

    Set-Content -Path $configPath -Value $content -Encoding UTF8
}

function Install-Files {
    if (-not (Test-Path $sourceExe)) {
        throw "Missing file: $sourceExe"
    }

    if (-not (Test-Path $sourceBenchmark)) {
        throw "Missing file: $sourceBenchmark"
    }

    New-Item -ItemType Directory -Path $installDir -Force | Out-Null
    New-Item -ItemType Directory -Path $dataDir -Force | Out-Null
    New-Item -ItemType Directory -Path $logDir -Force | Out-Null
    New-Item -ItemType Directory -Path $outDir -Force | Out-Null

    Copy-Item -Path $sourceExe -Destination $targetExe -Force
    Copy-Item -Path $sourceBenchmark -Destination $targetBenchmark -Force

    Write-ConfigFile
}

function Register-WeeklyTask {
    $action = New-ScheduledTaskAction `
        -Execute $targetExe `
        -Argument ('"{0}"' -f $targetBenchmark) `
        -WorkingDirectory $installDir

    $trigger = New-ScheduledTaskTrigger `
        -Weekly `
        -WeeksInterval 1 `
        -DaysOfWeek Sunday `
        -At 5:00AM

    $principal = New-ScheduledTaskPrincipal `
        -UserId "SYSTEM" `
        -LogonType ServiceAccount `
        -RunLevel Highest

    $settings = New-ScheduledTaskSettingsSet `
        -StartWhenAvailable `
        -AllowStartIfOnBatteries `
        -DontStopIfGoingOnBatteries

    Register-ScheduledTask `
        -TaskName $taskName `
        -Action $action `
        -Trigger $trigger `
        -Principal $principal `
        -Settings $settings `
        -Description "Runs SCA_Scanner weekly for Windows Server 2025 benchmark." `
        -Force | Out-Null
}

